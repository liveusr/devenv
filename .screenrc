register HELP "

                            ***  CUSTOM  HELP  ***


                            Command Key : Ctrl + \

 [ Show Help ]   [ Prev Tab ]    [ New  Tab ]    [ Next Tab ]    [ Close Tab ]
    C-\ + h        Ctrl + j        Ctrl + o        Ctrl + l         C-\ + k


                         < Press any key to return >
"

# assign name to a session :    Esc :sessionname <name>  -OR-  screen -S <name>
# assign name to a layout  :    Esc :layout title <name>
# assign name to a window  :    Esc :title <name>
# change window number     :    Esc :number <new_number>

sessionname "screen"        # Sets the default name for this session to "screen"

startup_message off         # turn off the startup message and copyright notice
autodetach on               # automatically detach on hangup
vbell off                   # turn off visual bell, and use audio bell instead

termcapinfo xterm* ti@:te@  # enable mouse scroll in copy mode
term xterm-256color         # set $TERM to use 256 colors
#mousetrack on              # use mouse to select regions

altscreen on                # clear vim window after closing vim
defscrollback 200000        # set scrollback buffer size to 200000 lines
layout save default         # remember the current arragement of regions/layouts
defdynamictitle off         # do not set prompt as the window title

escape ^\\                  # change window command key to 'Ctrl + \'

# display status line on the top
backtick 1 0 1 env TZ="America/New_York" date +"%Z %H:%M"
backtick 2 0 1 env TZ="Asia/Kolkata" date +"%Z %H:%M"
backtick 3 0 1 cat $HOME/.rate
hardstatus alwayslastline
hardstatus string "%{= dw}[%S] %{u kK}%2`%{= kR} [\\h] %{u kK} %= %{= kb} <j] %{u kK}  %-w%{w}%n %t%{-}%+w  %{= kb} [l> %{u kK} %= %{= kR} [\\k] %{u kK}%D %M %d%{= dw} %0c:%s"

# display caption for each region (split) at the bottom
caption splitonly
caption string "%?%F%{kK}%:%{u kK}%? %= %?%F %{g}<h]%{-} %{WK}%?  %n %t  %?%F%{kK} %{g}[k>%{-} %? %= %?%F%{r}[\\x]%{-}%:    %?"

# render vertical split line in black color and set command line fg to white
rendition so "wK"

bindkey  ^o  eval "layout new"  focus screen  # Ctl + o : new tab
bind      k  layout remove                    # Esc + k : remove tab
bind      l  eval "layout show"               # Esc + l : list tabs

bindkey  ^l  eval "layout next"               # Ctl + l : next tab
bindkey  ^j  eval "layout prev"               # Ctl + j : previous tab

bind      \  eval "split -v"    focus screen  # Esc + \ : vertical split
bind      -  eval "split"       focus screen  # Esc + - : horizontal split
bind      x  remove                           # Esc + x : remove split

bindkey  ^k  focus next                       # Ctl + k : next split
bindkey  ^h  focus prev                       # Ctl + h : previous split

bind      =  resize -b =                      # Esc + = : reset all splits
bind      ]  resize +5                        # Esc + ] : increase split size
bind      [  resize -5                        # Esc + [ : decrease split size

bind      o  screen                           # Esc + o : new shell

bindkey  ^n  next                             # Ctl + n : next shell
bindkey  ^b  prev                             # Ctl + b : previous shell

bindkey  ^y  copy                             # Ctl + y : enter copy/scroll mode
bind      p  paste .                          # Esc + p : paste selected text
bind      d  detach                           # Esc + d : detach screen session

bind      c  eval "clear" "scrollback 0" "scrollback 200000"                                    # Esc + c : Clear scrollback buffer
bind      s  exec sh -c 'screen -X hardcopy "$HOME/screen_$(date +%Y%m%d_%H%M%S).txt"'          # Esc + s : screenshot of visible screen
bind      S  exec sh -c 'screen -X hardcopy -h "$HOME/screen_$(date +%Y%m%d_%H%M%S)_full.txt"'  # Esc + S : screenshot of scrollback buffer

bind      t colon "title "                    # Esc + t : rename screen session
bind      T colon "sessionname "              # Esc + T : rename screen session

# Custom help text
bind h screen -t " [ HELP MENU ] " bash -c "head -n 12 $HOME/.screenrc | tail -n 11; read -n 1"
